<launch>
  <env name="GAZEBO_MODEL_PATH"
       value="$(find pal_gazebo_worlds)/models:$(optenv GAZEBO_MODEL_PATH)"/>

  <!-- Marker 1: Delivery Zone -->
  <node name="spawn_marker_1" pkg="gazebo_ros" type="spawn_model" output="screen"
        args="-sdf -model aruco_marker_250_6x6_1
              -file $(find pal_gazebo_worlds)/models/aruco_marker_250_6x6_1/aruco_marker_250_6x6.sdf
              -x 3.75 -y 2.35 -z 1.0 -R 0 -P 1.5708 -Y 3.40"/>

  <!-- Marker 2: Processing Zone -->
  <node name="spawn_marker_2" pkg="gazebo_ros" type="spawn_model" output="screen"
        args="-sdf -model aruco_marker_250_6x6_2
              -file $(find pal_gazebo_worlds)/models/aruco_marker_250_6x6_2/aruco_marker_250_6x6.sdf
              -x -2.09 -y -0.76 -z 1.0 -R 0 -P 1.5708 -Y -0.25"/>

  <!-- Marker 3: Pickup Zone -->
  <node name="spawn_marker_3" pkg="gazebo_ros" type="spawn_model" output="screen"
        args="-sdf -model aruco_marker_250_6x6_3
              -file $(find pal_gazebo_worlds)/models/aruco_marker_250_6x6_3/aruco_marker_250_6x6.sdf
              -x -2.93 -y 1.71 -z 1.0 -R 0 -P 1.5708 -Y 3.27"/>
</launch>
